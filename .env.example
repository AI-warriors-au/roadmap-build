# GitHub Personal Access Token for the GitHub MCP server in Cursor.
# Create one at https://github.com/settings/tokens
# Required scopes: repo (private repos), read:org (org repos)
#
# Or reuse your gh CLI session token:
#   export GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=ghp_your_token_here

# --- roadmap-build API (api/) ---

# HTTP port for the NestJS API
PORT=3000

# Frontend origin for CORS (required when the app calls the API cross-origin)
APP_ORIGIN=http://localhost:5173

# PostgreSQL — align with docker-compose.yml (#11)
DATABASE_URL=postgresql://roadmap-build:roadmap-build@localhost:5432/roadmap-build

# Google OAuth — redirect URI must target the API origin (not /api prefix)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# GitHub OAuth — redirect URI must target the API origin (not /api prefix)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

NODE_ENV=development

# Docker Compose only — run prisma db seed after migrations when api container starts (requires prisma.seed in api/package.json)
# SEED_DATABASE=true

# --- roadmap-build app (app/) ---

# Vite dev proxy target for /api (default http://localhost:3000; docker compose sets http://api:3000)
# VITE_API_PROXY_TARGET=http://localhost:3000
