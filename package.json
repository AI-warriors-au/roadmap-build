{
  "name": "learnmap",
  "private": true,
  "workspaces": [
    "api",
    "app"
  ],
  "scripts": {
    "build:api": "npm run build -w api",
    "lint:api": "npm run lint -w api",
    "start:api": "npm run start:dev -w api",
    "db:migration:generate": "npm run db:migration:generate -w api",
    "db:migration:deploy": "npm run db:migration:deploy -w api",
    "db:migration:reset": "npm run db:migration:reset -w api",
    "db:seed": "npm run db:seed -w api",
    "db:studio": "npm run db:studio -w api",

    "start:app": "npm run start:dev -w app",
    "lint:app": "npm run lint -w app",
    "build:app": "npm run build -w app",
    "test:app": "npm run test -w app"
  }
}
